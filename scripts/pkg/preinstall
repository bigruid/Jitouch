#!/bin/sh

set -u

AGENT_LABEL="com.jitouch.Jitouch.agent"

console_user() {
    /usr/bin/stat -f %Su /dev/console 2>/dev/null || true
}

user_home() {
    /usr/bin/dscl . -read "/Users/$1" NFSHomeDirectory 2>/dev/null | /usr/bin/sed 's/^NFSHomeDirectory: //'
}

stop_jitouch() {
    uid="$1"
    home="$2"
    plist="${home}/Library/LaunchAgents/com.jitouch.Jitouch.plist"

    /bin/launchctl bootout "gui/${uid}/${AGENT_LABEL}" >/dev/null 2>&1 || true
    if [ -f "$plist" ]; then
        /bin/launchctl bootout "gui/${uid}" "$plist" >/dev/null 2>&1 || true
    fi

    /usr/bin/pkill -x -u "$uid" Jitouch >/dev/null 2>&1 || true
    i=0
    while [ "$i" -lt 5 ]; do
        if ! /usr/bin/pgrep -x -u "$uid" Jitouch >/dev/null 2>&1; then
            return 0
        fi
        /bin/sleep 1
        i=$((i + 1))
    done

    /usr/bin/pkill -9 -x -u "$uid" Jitouch >/dev/null 2>&1 || true
}

user="$(console_user)"
if [ -z "$user" ] || [ "$user" = "root" ] || [ "$user" = "loginwindow" ]; then
    exit 0
fi

uid="$(/usr/bin/id -u "$user" 2>/dev/null || true)"
home="$(user_home "$user")"
if [ -z "$uid" ] || [ -z "$home" ]; then
    exit 0
fi

stop_jitouch "$uid" "$home"
exit 0
